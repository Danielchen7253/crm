{
  "expo": {
    "name": "CRM Mobile",
    "slug": "coolfix-crm-mobile",
    "scheme": "coolfixcrm",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coolfixpro.crm"
    },
    "android": {
      "package": "com.coolfixpro.crm",
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": ["expo-notifications"],
    "extra": {
      "apiBaseUrl": "https://coolfix-omni-api.onrender.com/api",
      "socketUrl": "https://coolfix-omni-api.onrender.com"
    }
  }
}
