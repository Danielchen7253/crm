{
  "manifest_version": 3,
  "name": "Coolfix CRM Customer Capture",
  "version": "0.4.0",
  "description": "滚动 Facebook、Messenger、Marketplace 客户列表时采集客户并导入 Coolfix CRM。",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://crm-8t7y.onrender.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://www.messenger.com/*",
    "https://messenger.com/*"
  ],
  "action": {
    "default_title": "Coolfix CRM 客户导入",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://www.messenger.com/*",
        "https://messenger.com/*"
      ],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
