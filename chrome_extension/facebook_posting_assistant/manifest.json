{
  "manifest_version": 3,
  "name": "Coolfix CRM Customer Capture",
  "version": "0.1.0",
  "description": "Save visible Facebook, Messenger, and Marketplace customers into Coolfix CRM.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://crm-8t7y.onrender.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://www.messenger.com/*",
    "https://messenger.com/*"
  ],
  "action": {
    "default_title": "Save customer to CRM",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://www.messenger.com/*",
        "https://messenger.com/*"
      ],
      "js": ["config.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
